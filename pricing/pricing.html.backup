    <div data-shared-footer data-footer></div>


    <script>
      // Billing toggle (Monthly/Annual)
      const billingToggle = document.getElementById("billing-toggle");
      const pricingPlans = {
        growth: { monthly: 25, yearly: 250, savings: 50 },
        scale: { monthly: 40, yearly: 400, savings: 80 }
      };
      
      // Update pricing display to show 17% savings
      function calculateAnnualSavings(monthly, yearly) {
        const monthlyEquivalent = Math.round(yearly / 12);
        return Math.round(((monthly - monthlyEquivalent) / monthly) * 100);
      }

      function updatePricing(isAnnual) {
        Object.keys(pricingPlans).forEach(planName => {
          const planCard = document.querySelector(`[data-plan="${planName}"]`);
          if (!planCard) return;

          const priceAmount = planCard.querySelector(".price-amount");
          const period = planCard.querySelector(".period");
          const savingsBadge = planCard.querySelector(".savings-badge");
          const plan = pricingPlans[planName];

          if (isAnnual) {
            // Calculate per-month equivalent (yearly / 12) and round to nearest dollar
            const monthlyEquivalent = Math.round(plan.yearly / 12);
            const savingsPercentage = calculateAnnualSavings(plan.monthly, plan.yearly);
            
            priceAmount.textContent = `$${monthlyEquivalent}`;
            period.textContent = "/mo";
            if (savingsBadge) {
              savingsBadge.textContent = `Save ${savingsPercentage}%`;
              savingsBadge.style.display = "inline-block";
            }
          } else {
            priceAmount.textContent = `$${plan.monthly}`;
            period.textContent = "/mo";
            if (savingsBadge) {
              savingsBadge.style.display = "none";
            }
          }
        });
      }

      if (billingToggle) {
        billingToggle.addEventListener("change", function() {
          updatePricing(this.checked);
        });
      }

      // Accordion functionality
      const accordionItems = Array.from(
        document.querySelectorAll("[data-accordion-item]")
      );
      if (accordionItems.length) {
        const accordions = accordionItems
          .map((item, index) => {
            const trigger = item.querySelector("[data-accordion-trigger]");
            const panel = item.querySelector("[data-accordion-panel]");
            if (!trigger || !panel) return null;

            const triggerId = trigger.id || `accordion-trigger-${index + 1}`;
            const panelId = panel.id || `accordion-panel-${index + 1}`;

            trigger.id = triggerId;
            panel.id = panelId;

            trigger.setAttribute("type", "button");
            trigger.setAttribute("aria-controls", panelId);
            trigger.setAttribute("aria-expanded", "false");

            panel.setAttribute("role", "region");
            panel.setAttribute("aria-labelledby", triggerId);
            panel.setAttribute("aria-hidden", "true");
            panel.style.maxHeight = "0px";

            return { item, trigger, panel };
          })
          .filter(Boolean);

        const closeAccordion = (accordion, { immediate = false } = {}) => {
          if (!accordion || !accordion.item.classList.contains("active"))
            return;
          const { item, trigger, panel } = accordion;

          trigger.setAttribute("aria-expanded", "false");
          panel.setAttribute("aria-hidden", "true");

          const finishClose = () => {
            item.classList.remove("active");
            panel.removeEventListener("transitionend", onTransitionEnd);
          };

          const onTransitionEnd = (event) => {
            if (event.propertyName !== "max-height") return;
            finishClose();
          };

          if (immediate) {
            panel.style.maxHeight = "0px";
            finishClose();
            return;
          }

          panel.addEventListener("transitionend", onTransitionEnd);
          panel.style.maxHeight = `${panel.scrollHeight}px`;
          requestAnimationFrame(() => {
            panel.style.maxHeight = "0px";
          });
        };

        const openAccordion = (accordion) => {
          if (!accordion) return;
          const { item, trigger, panel } = accordion;
          if (item.classList.contains("active")) {
            panel.style.maxHeight = `${panel.scrollHeight}px`;
            panel.setAttribute("aria-hidden", "false");
            trigger.setAttribute("aria-expanded", "true");
            return;
          }

          accordions.forEach((other) => {
            if (other !== accordion) {
              closeAccordion(other);
            }
          });

          item.classList.add("active");
          trigger.setAttribute("aria-expanded", "true");
          panel.setAttribute("aria-hidden", "false");
          panel.style.maxHeight = `${panel.scrollHeight}px`;
        };

        const toggleAccordion = (accordion) => {
          if (!accordion) return;
          if (accordion.item.classList.contains("active")) {
            closeAccordion(accordion);
          } else {
            openAccordion(accordion);
          }
        };

        accordions.forEach((accordion, index) => {
          const { trigger } = accordion;

          trigger.addEventListener("click", () => toggleAccordion(accordion));

          trigger.addEventListener("keydown", (event) => {
            switch (event.key) {
              case "Enter":
              case " ":
                event.preventDefault();
                toggleAccordion(accordion);
                break;
              case "ArrowDown":
              case "ArrowRight": {
                event.preventDefault();
                const next = accordions[(index + 1) % accordions.length];
                next?.trigger.focus();
                break;
              }
              case "ArrowUp":
              case "ArrowLeft": {
                event.preventDefault();
                const previous =
                  accordions[
                    (index - 1 + accordions.length) % accordions.length
                  ];
                previous?.trigger.focus();
                break;
              }
              case "Home":
                event.preventDefault();
                accordions[0]?.trigger.focus();
                break;
              case "End":
                event.preventDefault();
                accordions[accordions.length - 1]?.trigger.focus();
                break;
            }
          });
        });

        const onAccordionResize = () => {
          accordions.forEach((accordion) => {
            if (accordion?.item.classList.contains("active")) {
              accordion.panel.style.maxHeight = `${accordion.panel.scrollHeight}px`;
            }
          });
        };

        window.addEventListener("resize", onAccordionResize);
      }

      // ROI Calculator Modal
      const roiModal = document.getElementById("roi-calculator-modal");
      const roiTrigger = document.getElementById("roi-calculator-trigger");
      const roiClose = document.getElementById("roi-modal-close");
      const roiBackdrop = document.getElementById("roi-modal-backdrop");
      const roiIndustry = document.getElementById("roi-industry");
      const roiVisitors = document.getElementById("roi-visitors");
      const roiVisitorsDisplay = document.getElementById("roi-visitors-display");
      const roiConversionRate = document.getElementById("roi-conversion-rate");
      const roiAOV = document.getElementById("roi-aov");
      const roiCrIncrement = document.getElementById("roi-cr-increment");
      const roiCrDecrement = document.getElementById("roi-cr-decrement");
      const roiAovIncrement = document.getElementById("roi-aov-increment");
      const roiAovDecrement = document.getElementById("roi-aov-decrement");
      const roiMonthly = document.getElementById("roi-monthly");
      const roiYearly = document.getElementById("roi-yearly");
      const roiUplift = document.getElementById("roi-uplift");
      const roiNewCr = document.getElementById("roi-new-cr");

      function calculateROI() {
        const uplift = parseFloat(roiIndustry.value);
        const visitors = parseInt(roiVisitors.value);
        const conversionRate = parseFloat(roiConversionRate.value);
        const aov = parseInt(roiAOV.value);

        const currentConversions = (visitors * conversionRate) / 100;
        const currentRevenue = currentConversions * aov;
        
        const newConversionRate = conversionRate * (1 + uplift / 100);
        const newConversions = (visitors * newConversionRate) / 100;
        const newRevenue = newConversions * aov;
        
        const additionalMonthly = newRevenue - currentRevenue;
        const additionalYearly = additionalMonthly * 12;

        roiMonthly.textContent = `+$${Math.round(additionalMonthly).toLocaleString()} / month`;
        roiYearly.textContent = `+$${Math.round(additionalYearly).toLocaleString()} / year`;
        roiUplift.textContent = `+${uplift}%`;
        roiNewCr.textContent = `${newConversionRate.toFixed(2)}%`;
      }

      function openROIModal() {
        if (roiModal) {
          roiModal.style.display = "flex";
          document.body.style.overflow = "hidden";
          calculateROI();
        }
      }

      function closeROIModal() {
        if (roiModal) {
          roiModal.style.display = "none";
          document.body.style.overflow = "";
        }
      }

      if (roiTrigger) {
        roiTrigger.addEventListener("click", openROIModal);
      }
      if (roiClose) {
        roiClose.addEventListener("click", closeROIModal);
      }
      if (roiBackdrop) {
        roiBackdrop.addEventListener("click", closeROIModal);
      }

      // ROI Calculator inputs
      if (roiVisitors) {
        roiVisitors.addEventListener("input", function() {
          roiVisitorsDisplay.textContent = parseInt(this.value).toLocaleString();
          calculateROI();
        });
      }
      if (roiIndustry) {
        roiIndustry.addEventListener("change", calculateROI);
      }
      if (roiConversionRate) {
        roiConversionRate.addEventListener("input", function() {
          let val = parseFloat(this.value);
          if (val < 0.1) val = 0.1;
          if (val > 20) val = 20;
          this.value = val.toFixed(1);
          calculateROI();
        });
      }
      if (roiAOV) {
        roiAOV.addEventListener("input", function() {
          let val = parseInt(this.value);
          if (val < 1) val = 1;
          if (val > 5000) val = 5000;
          this.value = val;
          calculateROI();
        });
      }
      if (roiCrIncrement) {
        roiCrIncrement.addEventListener("click", function() {
          let val = parseFloat(roiConversionRate.value);
          if (val < 20) {
            roiConversionRate.value = Math.min(20, val + 0.1).toFixed(1);
            calculateROI();
          }
        });
      }
      if (roiCrDecrement) {
        roiCrDecrement.addEventListener("click", function() {
          let val = parseFloat(roiConversionRate.value);
          if (val > 0.1) {
            roiConversionRate.value = Math.max(0.1, val - 0.1).toFixed(1);
            calculateROI();
          }
        });
      }
      if (roiAovIncrement) {
        roiAovIncrement.addEventListener("click", function() {
          let val = parseInt(roiAOV.value);
          if (val < 5000) {
            roiAOV.value = Math.min(5000, val + 1);
            calculateROI();
          }
        });
      }
      if (roiAovDecrement) {
        roiAovDecrement.addEventListener("click", function() {
          let val = parseInt(roiAOV.value);
          if (val > 1) {
            roiAOV.value = Math.max(1, val - 1);
            calculateROI();
          }
        });
      }

      // Close modal on Escape key
      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape" && roiModal && roiModal.style.display === "flex") {
          closeROIModal();
        }
      });

      // Scroll reveal
      const revealElements = document.querySelectorAll(".scroll-reveal");
      if (revealElements.length) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );

        revealElements.forEach((el) => revealObserver.observe(el));
      }
    </script>

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "grona.ai",
        "url": "https://grona.ai/",
        "logo": "https://grona.ai/assets/logo.svg",
        "sameAs": [
          "https://www.linkedin.com/company/grona-ai",
          "https://x.com/grona_ai"
        ],
        "description": "Agentic CRO copilot that plans, launches, and learns from a simple prompt."
      }
    </script>

    <!-- Shared JavaScript -->
    <script src="/shared/shared.js"></script>
    <!-- Ensure header loads if auto-load didn't work -->
    <script>
      // Fallback: ensure header loads if it's missing
      (function() {
        function initThemeToggleAfterLoad() {
          // Use the global initThemeToggle function if available (from shared.js)
          if (window.initThemeToggle) {
            window.initThemeToggle();
            return;
          }
          
          // Fallback: manual initialization if shared.js hasn't loaded yet
          const themeToggle = document.getElementById("theme-toggle");
          if (!themeToggle) return;
          
          // Check if already initialized
          if (themeToggle.dataset.initialized === 'true') return;
          
          const html = document.documentElement;
          const safeStorage = window.__gronaStorage;
          
          // Check for saved theme preference or default to light mode
          const currentTheme = (safeStorage && safeStorage.getItem("theme")) || "light";
          html.setAttribute("data-theme", currentTheme);
          
          // Update icon and logo based on current theme
          function updateIcon() {
            const isDark = html.getAttribute("data-theme") === "dark";
            
            // Update theme toggle icon
            themeToggle.innerHTML = isDark
              ? `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>`
              : `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5"></circle>
                  <line x1="12" y1="1" x2="12" y2="3"></line>
                  <line x1="12" y1="21" x2="12" y2="23"></line>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                  <line x1="1" y1="12" x2="3" y2="12"></line>
                  <line x1="21" y1="12" x2="23" y2="12"></line>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>`;
            
            // Update logos across the page
            const themedLogos = document.querySelectorAll("[data-theme-logo]");
            if (themedLogos.length) {
              themedLogos.forEach((logo) => {
                const lightSrc = logo.getAttribute("data-logo-light") || "/assets/logo.png";
                const darkSrc = logo.getAttribute("data-logo-dark") || "/assets/Grona_light.png";
                logo.setAttribute("src", isDark ? darkSrc : lightSrc);
              });
            } else {
              const logoImg = document.querySelector(".brand img");
              if (logoImg) {
                logoImg.src = isDark ? "/assets/Grona_light.png" : "/assets/logo.png";
              }
            }
          }
          
          updateIcon();
          
          // Add click listener
          themeToggle.addEventListener("click", () => {
            const currentTheme = html.getAttribute("data-theme");
            const newTheme = currentTheme === "dark" ? "light" : "dark";
            
            html.setAttribute("data-theme", newTheme);
            if (safeStorage) {
              try {
                safeStorage.setItem("theme", newTheme);
              } catch (err) {
                console.warn('Unable to persist theme selection.', err);
              }
            }
            updateIcon();
            themeToggle.classList.add("toggled");
            setTimeout(() => themeToggle.classList.remove("toggled"), 220);
          });
          
          // Mark as initialized
          themeToggle.dataset.initialized = 'true';
        }
        
        function ensureHeader() {
          // Check if header already exists
          if (document.querySelector('header.navbar')) {
            // Header exists, make sure theme toggle is initialized
            setTimeout(initThemeToggleAfterLoad, 50);
            return; // Header already loaded
          }
          
          // Try to load header directly
          const headerTarget = document.querySelector('[data-shared-header]');
          if (!headerTarget) {
            console.warn('Header target element not found');
            return;
          }
          
          // Try manual fetch and insert
          fetch('/shared/header.html')
            .then(response => {
              if (!response.ok) {
                throw new Error(`Failed to load header: ${response.statusText}`);
              }
              return response.text();
            })
            .then(html => {
              headerTarget.insertAdjacentHTML('beforebegin', html);
              console.log('Header loaded successfully');
              // Initialize theme toggle after header loads
              // Try multiple times in case shared.js loads after this
              setTimeout(initThemeToggleAfterLoad, 50);
              setTimeout(initThemeToggleAfterLoad, 200);
              setTimeout(initThemeToggleAfterLoad, 500);
            })
            .catch(error => {
              console.error('Error loading header:', error);
              // Try using loader function if available
              if (window.loadSharedComponents) {
                window.loadSharedComponents({ header: true, footer: false });
                setTimeout(initThemeToggleAfterLoad, 200);
                setTimeout(initThemeToggleAfterLoad, 500);
              }
            });
        }
        
        // Wait for DOM to be ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() {
            setTimeout(ensureHeader, 100);
          });
        } else {
          // DOM already ready, check after a short delay
          setTimeout(ensureHeader, 100);
        }
        
        // Also try after a longer delay as final fallback
        setTimeout(function() {
          if (!document.querySelector('header.navbar')) {
            ensureHeader();
          } else {
            initThemeToggleAfterLoad();
          }
        }, 500);
      })();
    </script>
  </body>
</html>
