          <!-- Monthly Visitors Slider -->
          <div class="roi-field" style="margin-bottom: 12px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
              <label style="font-weight: 500; font-size: 14px;">Monthly Visitors</label>
              <span id="roi-visitors-display" style="font-size: 14px; font-weight: 600; color: var(--pricing-accent);">10,000</span>
            </div>
            <p style="font-size: 12px; color: var(--muted); margin-bottom: 6px;">(Unique visitors per month)</p>
            <input type="range" id="roi-visitors" min="1000" max="500000" step="1000" value="10000" style="width: 100%; height: 4px; background: var(--line); border-radius: 4px; appearance: none; cursor: pointer;">
          </div>

          <!-- Conversion Rate Stepper -->
          <div class="roi-field" style="margin-bottom: 12px;">
            <label style="display: block; font-weight: 500; font-size: 14px; margin-bottom: 4px;">Current Conversion Rate (%)</label>
            <div style="display: flex; align-items: center; gap: 8px;">
              <button id="roi-cr-decrement" class="roi-stepper-btn" aria-label="Decrease conversion rate">−</button>
              <input type="number" id="roi-conversion-rate" value="2.5" min="0.1" max="20" step="0.1" style="width: 70px; padding: 4px 8px; text-align: center; border-radius: 8px; border: 1px solid var(--line); background: var(--bg); font-size: 14px; font-weight: 600; height: 32px;">
              <button id="roi-cr-increment" class="roi-stepper-btn" aria-label="Increase conversion rate">+</button>
              <span style="font-size: 14px; color: var(--muted);">%</span>
            </div>
          </div>

          <!-- AOV Stepper -->
          <div class="roi-field" style="margin-bottom: 16px;">
            <label style="display: block; font-weight: 500; font-size: 14px; margin-bottom: 4px;">Average Order Value ($)</label>
            <div style="display: flex; align-items: center; gap: 8px;">
              <button id="roi-aov-decrement" class="roi-stepper-btn" aria-label="Decrease AOV">−</button>
              <input type="number" id="roi-aov" value="100" min="1" max="5000" step="1" style="width: 70px; padding: 4px 8px; text-align: center; border-radius: 8px; border: 1px solid var(--line); background: var(--bg); font-size: 14px; font-weight: 600; height: 32px;">
              <button id="roi-aov-increment" class="roi-stepper-btn" aria-label="Increase AOV">+</button>
              <span style="font-size: 14px; color: var(--muted);">$</span>
            </div>
          </div>

          <!-- Projected Results -->
          <div class="roi-results" style="background: #F9FAFB; border-radius: 14px; padding: 16px; margin-bottom: 16px;">
            <h3 style="font-size: 16px; font-weight: 600; margin: 0 0 4px 0;">Projected Impact</h3>
            <p style="font-size: 12px; color: var(--muted); margin: 0 0 12px 0;">(Based on typical uplift for your industry)</p>
            
            <div style="margin-bottom: 12px;">
              <p style="font-size: 13px; color: var(--muted); margin: 0 0 6px 0;">Your site could earn:</p>
              <div id="roi-monthly" style="font-size: 24px; font-weight: 700; color: #16a34a; line-height: 1.2;">+$0 / month</div>
              <div id="roi-yearly" style="font-size: 18px; font-weight: 700; color: #16a34a; margin-top: 4px;">+$0 / year</div>
            </div>

            <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(0,0,0,0.06);">
