<!DOCTYPE html>
<html lang="en" data-shared-auto-load>
  <head>
    <script src="/shared/loader.js"></script>
    <link rel="stylesheet" href="/shared/shared.css" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pricing — grona.ai</title>
    <meta
      name="description"
      content="Choose the right plan for your optimization needs. Start free or scale with Growth, Scale, or Enterprise plans."
    />

    <!-- Open Graph / Twitter -->
    <meta property="og:title" content="Pricing — grona.ai" />
    <meta
      property="og:description"
      content="Start optimizing. Scale with plans that match your experimentation needs."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://grona.ai/pricing/" />
    <meta property="og:image" content="https://grona.ai/assets/Grona_OpenGraph.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://grona.ai/assets/Grona_OpenGraph.png" />
    <meta name="keywords" content="CRO pricing, conversion optimization pricing, AI CRO plans, CRO software pricing, A/B testing pricing, conversion optimization cost, CRO platform pricing" />
    <meta name="author" content="Grona.ai" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href="https://grona.ai/pricing/" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/Grona-favicon-v1.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/Grona-favicon-v1.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/Grona-favicon-v1.png" />

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NXBH5J6M');</script>
    <!-- End Google Tag Manager -->
    <style>
      /* ========================================
       BRAND TOKENS — tuned to your logo
       ======================================== */
       
      :root {
        --green-900: #0f3e35;
        --green-800: #0b6b53;
        --green-400: #7fd97a;
        --ink: #0f172a;
        --muted: #5b6475;
        --line: #e8ecef;
        --bg: #ffffff;
        --bg-soft: #f6fbf8;
        --radius: 14px;
        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.06);
        --shadow-md: 0 10px 30px rgba(11, 107, 83, 0.1);
        --max: 1120px;
        --space-1: 8px;
        --space-2: 12px;
        --space-3: 16px;
        --space-4: 24px;
        --space-5: 32px;
        --space-6: 48px;
        --space-7: 64px;
        --space-8: 92px;
        --ff-display: "Oracle ABC", "Poppins", ui-sans-serif, system-ui,
          -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, "Noto Sans",
          sans-serif;
        --ff-body: "Oracle ABC", "Inter", ui-sans-serif, system-ui,
          -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, "Noto Sans",
          sans-serif;
        --pricing-accent: #064E3D;
      }

      /* Dark mode variables */
      [data-theme="dark"] {
        --green-800: #bbe55b;
        --ink: #f8fafc;
        --muted: #94a3b8;
        --line: #334155;
        --bg: #0f172a;
        --bg-soft: #1e293b;
        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
        --shadow-md: 0 10px 30px rgba(0, 0, 0, 0.4);
        --pricing-accent: #BCE55D;
      }

      /* RESET */
      * {
        box-sizing: border-box;
      }
      html:focus-within {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--muted);
        font-family: var(--ff-body);
        line-height: 1.6;
        overflow-x: hidden;
      }
      img {
        max-width: 100%;
        display: block;
      }
      a {
        color: var(--green-800);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .container {
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 var(--space-4);
      }
      .section {
        padding: var(--space-8) 0;
      }

      h1, h2, h3 {
        font-family: var(--ff-display);
        color: var(--ink);
        letter-spacing: -0.02em;
        margin: 0 0 var(--space-3);
      }
      h1 {
        font-size: clamp(36px, 4.5vw, 56px);
        line-height: 1.1;
      }
      h2 {
        font-size: clamp(26px, 3vw, 34px);
      }
      h3 {
        font-size: clamp(20px, 2.2vw, 22px);
      }
      p {
        margin: 0 0 var(--space-3);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 48px;
        padding: 0 18px;
        border-radius: 12px;
        border: 1px solid transparent;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.08s ease, box-shadow 0.2s ease;
      }
      .btn-primary {
        background: var(--pricing-accent);
        color: #fff !important;
        font-weight: 700;
        box-shadow: var(--shadow-sm);
      }
      .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        text-decoration: none;
      }
      .btn-ghost {
        background: var(--bg);
        border-color: var(--line);
        color: var(--ink);
      }
      .btn-ghost:hover {
        text-decoration: none;
      }


      /* HERO */
      .pricing-hero {
        text-align: center;
        padding-top: 52px;
        padding-bottom: 24px;
        max-width: 720px;
        margin: 0 auto;
      }
      .pricing-hero h1 {
        margin-bottom: 12px;
      }
      .pricing-hero p {
        font-size: 18px;
        line-height: 26px;
        font-weight: 500;
        color: #4B5563;
        margin: 0 0 12px;
      }

      /* BILLING TOGGLE */
      .billing-toggle-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: var(--space-3);
        margin: 16px 0 var(--space-8) 0;
      }
      .billing-toggle-label {
        font-weight: 500;
        color: var(--muted);
        font-size: 14px;
      }
      .billing-toggle {
        position: relative;
        display: inline-block;
        width: 56px;
        height: 32px;
      }
      .billing-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
      }
      .billing-toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--line);
        transition: 0.3s;
        border-radius: 32px;
      }
      .billing-toggle-slider:before {
        position: absolute;
        content: "";
        height: 24px;
        width: 24px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: 0.3s;
        border-radius: 50%;
      }
      .billing-toggle input:checked + .billing-toggle-slider {
        background-color: var(--pricing-accent);
      }
      .billing-toggle input:checked + .billing-toggle-slider:before {
        transform: translateX(24px);
      }
      .billing-toggle input:focus-visible + .billing-toggle-slider {
        outline: 2px solid var(--pricing-accent);
        outline-offset: 2px;
      }
      .savings-badge {
        display: inline-block;
        background: var(--pricing-accent);
        color: #fff;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        margin-left: var(--space-2);
      }

      /* PRICING TIERS */
      .pricing-tiers {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-4);
        margin: var(--space-8) 0;
        padding-bottom: var(--space-5);
      }
      .pricing-card {
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: var(--space-5);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .pricing-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
      }
      [data-theme="dark"] .pricing-card {
        background: var(--bg-soft);
        border-color: var(--line);
      }
      [data-theme="dark"] .pricing-card-feature-group-title {
        color: var(--muted);
      }
      [data-theme="dark"] .pricing-card-feature-group li {
        color: var(--muted);
      }
      [data-theme="dark"] .pricing-card-feature-group li::before {
        color: var(--pricing-accent);
      }
      [data-theme="dark"] .pricing-hero p {
        color: var(--muted);
      }
      .pricing-card.featured {
        border: 2px solid var(--pricing-accent);
        position: relative;
        background: rgba(11, 107, 83, 0.05);
      }
      [data-theme="dark"] .pricing-card.featured {
        background: rgba(187, 229, 91, 0.08);
      }
      .pricing-card.featured::before {
        content: "Most Popular";
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--pricing-accent);
        color: #fff;
        padding: 4px 16px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
      }
      .pricing-card-feature-group {
        margin-bottom: var(--space-6);
      }
      .pricing-card-feature-group-title {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        margin-bottom: var(--space-3);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
      }
      .pricing-card-feature-group-icon {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }
      .pricing-card-feature-group ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .pricing-card-feature-group li {
        padding: var(--space-2) 0;
        font-size: 15px;
        color: var(--muted);
        display: flex;
        align-items: start;
        gap: var(--space-2);
      }
      .pricing-card-feature-group li::before {
        content: "✓";
        color: var(--pricing-accent);
        font-weight: 700;
        flex-shrink: 0;
      }
      .pricing-card-header {
        margin-bottom: var(--space-4);
        min-height: 140px;
      }
      .pricing-card-name {
        font-size: 24px;
        font-weight: 700;
        color: var(--ink);
        margin: 0 0 var(--space-2);
      }
      .pricing-card-price {
        font-size: 36px;
        font-weight: 700;
        color: var(--pricing-accent);
        margin: 0;
        display: flex;
        align-items: baseline;
        gap: var(--space-1);
        flex-wrap: wrap;
        min-height: 48px;
      }
      .pricing-card.featured .pricing-card-price {
        font-size: 32px;
      }
      .pricing-card-price small {
        font-size: 16px;
        font-weight: 500;
        color: var(--muted);
      }
      .pricing-card-price .period {
        font-size: 16px;
        font-weight: 500;
        color: var(--muted);
      }
      .pricing-card-price .savings-badge {
        display: inline-block;
        width: 100%;
        margin-top: var(--space-1);
        margin-left: 0;
      }
      .pricing-card-target {
        font-size: 14px;
        color: var(--muted);
        margin-top: var(--space-2);
        min-height: 40px;
      }
      .pricing-card-features {
        flex: 1;
        margin: var(--space-4) 0;
      }
      .pricing-card-features ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .pricing-card-features li {
        padding: var(--space-2) 0;
        font-size: 15px;
        color: var(--muted);
        display: flex;
        align-items: start;
        gap: var(--space-2);
      }
      .pricing-card-features li::before {
        content: "✓";
        color: var(--pricing-accent);
        font-weight: 700;
        flex-shrink: 0;
      }
      .pricing-card-cta {
        margin-top: var(--space-4);
      }

      /* FEATURE COMPARISON TABLE */
      .feature-table-section {
        margin: var(--space-8) 0;
        padding: var(--space-7) 0;
      }
      .feature-table-wrapper {
        overflow-x: auto;
        margin: var(--space-6) 0;
      }
      .feature-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 800px;
      }
      .feature-table th,
      .feature-table td {
        padding: 14px 18px;
        text-align: left;
        border-bottom: 1px solid rgba(232, 236, 239, 0.5);
      }
      .feature-table th {
        font-weight: 600;
        color: var(--ink);
        background: var(--bg-soft);
        position: sticky;
        top: 0;
        text-align: center;
        font-size: 14px;
      }
      [data-theme="dark"] .feature-table th {
        background: rgba(30, 41, 59, 0.5);
      }
      .feature-table td {
        color: var(--muted);
        font-size: 14px;
      }
      .feature-table td:first-child {
        font-weight: 500;
        color: var(--ink);
        background: rgba(0, 0, 0, 0.03);
        position: sticky;
        left: 0;
        z-index: 5;
      }
      [data-theme="dark"] .feature-table td:first-child {
        background: rgba(0, 0, 0, 0.2);
      }
      .feature-table tbody tr:nth-child(even) {
        background: rgba(0, 0, 0, 0.02);
      }
      [data-theme="dark"] .feature-table tbody tr:nth-child(even) {
        background: rgba(255, 255, 255, 0.02);
      }
      .feature-table tbody tr:hover {
        background: var(--bg-soft);
      }
      [data-theme="dark"] .feature-table tbody tr:hover {
        background: rgba(30, 41, 59, 0.3);
      }
      .feature-table .category-row {
        border-top: 1px solid var(--line);
      }
      .feature-table .category-row td {
        font-weight: 600;
        font-size: 13px;
        padding-top: 12px;
        padding-bottom: 8px;
        background: var(--bg);
        border-bottom: none;
      }
      [data-theme="dark"] .feature-table .category-row td {
        background: var(--bg);
      }
      .feature-table .category-row td:first-child {
        background: var(--bg);
      }
      .feature-table .growth-column {
        background: rgba(11, 107, 83, 0.05);
        border-left: 2px solid rgba(11, 107, 83, 0.3);
        border-right: 2px solid rgba(11, 107, 83, 0.3);
        text-align: center;
      }
      [data-theme="dark"] .feature-table .growth-column {
        background: rgba(187, 229, 91, 0.08);
        border-left-color: rgba(187, 229, 91, 0.3);
        border-right-color: rgba(187, 229, 91, 0.3);
      }
      .feature-table .check {
        color: var(--pricing-accent);
        font-weight: 700;
        text-align: center;
      }
      .feature-table .check-starter {
        color: rgba(91, 100, 117, 0.4);
      }
      .feature-table .dash {
        color: var(--muted);
        text-align: center;
      }

      /* FAQ */
      .faq-section {
        background: var(--bg);
        padding: var(--space-7) 0;
      }
      [data-theme="dark"] .faq-section {
        background: var(--bg);
      }
      .faq-container {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 var(--space-4);
      }
      .faq-container h2 {
        text-align: center;
        margin-bottom: var(--space-3);
      }
      .faq-container > p {
        text-align: center;
        font-size: 18px;
        color: var(--muted);
        margin-bottom: var(--space-6);
      }
      .accordion {
        display: grid;
        gap: 12px;
      }
      .accordion-item {
        border: 1px solid rgba(203, 213, 225, 0.6);
        border-radius: 16px;
        background: #fff;
        overflow: hidden;
        transition: border 0.2s cubic-bezier(0.22, 1, 0.36, 1);
      }
      [data-theme="dark"] .accordion-item {
        background: rgba(15, 23, 42, 0.92);
        border-color: rgba(94, 110, 140, 0.45);
      }
      .accordion-trigger {
        width: 100%;
        position: relative;
        background: none;
        border: 0;
        padding: 20px 56px 20px 24px;
        text-align: left;
        font-weight: 600;
        font-size: 16px;
        color: var(--ink);
        cursor: pointer;
        font-family: var(--ff-body);
      }
      [data-theme="dark"] .accordion-trigger {
        color: #f1f5f9;
      }
      .accordion-trigger:focus-visible {
        outline: 2px solid var(--pricing-accent);
        outline-offset: 4px;
      }
      .accordion-trigger .chevron {
        position: absolute;
        right: 24px;
        font-size: 18px;
        transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .accordion-item.active .chevron {
        transform: rotate(180deg);
      }
      .accordion-item.active {
        border-left: 4px solid var(--pricing-accent);
      }
      .accordion-panel {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.2s cubic-bezier(0.22, 1, 0.36, 1);
        padding: 0 24px;
      }
      .accordion-item.active .accordion-panel {
        padding-bottom: 20px;
      }
      .accordion-panel p {
        margin: 0;
        color: #475569;
        font-size: 15px;
        line-height: 1.6;
      }
      [data-theme="dark"] .accordion-panel p {
        color: #cbd5f5;
      }
      .accordion-panel ul {
        margin: var(--space-3) 0;
        padding-left: var(--space-4);
      }
      .accordion-panel li {
        margin: var(--space-2) 0;
        color: #475569;
      }
      [data-theme="dark"] .accordion-panel li {
        color: #cbd5f5;
      }

      /* CTA SECTION */
      .cta-section {
        text-align: center;
        padding: var(--space-8) 0;
        background: var(--bg-soft);
        border-radius: var(--radius);
        margin: var(--space-8) 0;
      }
      .cta-section h2 {
        margin-bottom: var(--space-4);
      }
      .cta-section p {
        font-size: 18px;
        color: var(--muted);
        margin-bottom: var(--space-5);
      }
      .cta-buttons {
        display: flex;
        gap: var(--space-3);
        justify-content: center;
        flex-wrap: wrap;
      }
      [data-theme="dark"] .cta-section {
        background: var(--bg-soft);
      }
      [data-theme="dark"] .cta-section h2 {
        color: var(--ink);
      }
      [data-theme="dark"] .cta-section p {
        color: var(--muted);
      }

      /* ROI MODAL */
      .roi-modal {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
      }
      .roi-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.44);
        background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='1' cy='1' r='1' fill='white' opacity='0.04'/%3E%3C/svg%3E");
        cursor: pointer;
      }
      .roi-modal-content {
        position: relative;
        background: var(--bg);
        border-radius: 16px;
        width: 100%;
        max-width: 440px;
        max-height: 80vh;
        overflow-y: auto;
        padding: 24px;
        box-shadow: 0px 8px 28px rgba(0, 0, 0, 0.18);
        z-index: 1;
      }
      [data-theme="dark"] .roi-modal-content {
        background: var(--bg-soft);
      }
      .roi-modal-header {
        margin-bottom: 16px;
      }
      .roi-modal-close {
        background: none;
        border: 0;
        font-size: 24px;
        line-height: 1;
        color: var(--muted);
        cursor: pointer;
        padding: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: -4px;
        transition: color 0.2s ease;
      }
      .roi-modal-close:hover {
        color: var(--ink);
      }
      .roi-modal-body {
        margin-top: 10px;
      }
      .roi-stepper-btn {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        border: 1px solid var(--line);
        background: var(--bg);
        color: var(--ink);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        line-height: 1;
        transition: all 0.2s ease;
      }
      .roi-stepper-btn:hover {
        border-color: var(--pricing-accent);
        background: rgba(11, 107, 83, 0.05);
      }
      [data-theme="dark"] .roi-stepper-btn {
        background: var(--bg-soft);
      }
      [data-theme="dark"] .roi-stepper-btn:hover {
        background: rgba(187, 229, 91, 0.1);
      }
      #roi-visitors {
        accent-color: var(--pricing-accent);
      }
      [data-theme="dark"] .roi-results {
        background: rgba(30, 41, 59, 0.5);
      }
      [data-theme="dark"] .roi-results > div > div {
        border-top-color: rgba(255, 255, 255, 0.1);
      }
      [data-theme="dark"] .roi-modal-header p {
        color: var(--muted);
      }
      [data-theme="dark"] .roi-results h3 {
        color: var(--ink);
      }
      [data-theme="dark"] .roi-results p {
        color: var(--muted);
      }
      [data-theme="dark"] #roi-monthly,
      [data-theme="dark"] #roi-yearly {
        color: var(--pricing-accent);
      }
      [data-theme="dark"] #roi-uplift {
        color: var(--pricing-accent);
      }
      [data-theme="dark"] #roi-new-cr {
        color: var(--ink);
      }
      [data-theme="dark"] select,
      [data-theme="dark"] input[type="number"] {
        background: var(--bg);
        color: var(--ink);
        border-color: var(--line);
      }

      /* OPTIMIZATION LOOP */
      .optimization-loop {
        padding: var(--space-7) 0;
        background: var(--bg-soft);
      }
      [data-theme="dark"] .optimization-loop {
        background: rgba(30, 41, 59, 0.3);
      }
      .optimization-loop h2 {
        text-align: center;
        margin-bottom: var(--space-7);
      }
      .optimization-steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-5);
        max-width: 960px;
        margin: 0 auto;
        position: relative;
      }
      .optimization-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
      }
      .optimization-step-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(11, 107, 83, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-4);
        transition: background 0.2s ease;
      }
      [data-theme="dark"] .optimization-step-icon {
        background: rgba(187, 229, 91, 0.15);
      }
      [data-theme="dark"] .optimization-step h3 {
        color: var(--ink);
      }
      [data-theme="dark"] .optimization-step p {
        color: var(--muted);
      }
      [data-theme="dark"] .optimization-step-arrow {
        color: var(--pricing-accent);
      }
      .optimization-step-icon svg {
        width: 32px;
        height: 32px;
        color: var(--pricing-accent);
      }
      .optimization-step h3 {
        font-size: 18px;
        font-weight: 600;
        margin: 0 0 var(--space-2);
      }
      .optimization-step p {
        font-size: 14px;
        color: var(--muted);
        margin: 0;
      }
      .optimization-step-arrow {
        position: absolute;
        top: 32px;
        left: calc(50% + 2rem);
        width: calc(100% - 4rem);
        display: none;
        align-items: center;
        justify-content: center;
        color: var(--pricing-accent);
        opacity: 0.4;
      }
      .optimization-step-arrow svg {
        width: 24px;
        height: 24px;
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 0.7; }
      }
      @media (min-width: 768px) {
        .optimization-step-arrow {
          display: flex;
        }
      }
      @media (max-width: 768px) {
        .optimization-steps {
          grid-template-columns: 1fr;
          gap: var(--space-6);
        }
      }

      /* INTEGRATIONS */
      .integrations-section {
        padding: var(--space-7) 0;
        background: var(--bg);
      }
      .integrations-section h2 {
        text-align: center;
        margin-bottom: var(--space-3);
      }
      .integrations-section > .container > p {
        text-align: center;
        color: var(--muted);
        margin-bottom: var(--space-6);
      }
      .integrations-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-4);
        max-width: 960px;
        margin: 0 auto var(--space-6);
      }
      @media (min-width: 768px) {
        .integrations-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }
      .integration-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--bg);
        padding: 18px;
        transition: all 0.2s ease;
      }
      .integration-card:hover {
        border-color: var(--pricing-accent);
        box-shadow: var(--shadow-sm);
      }
      [data-theme="dark"] .integration-card {
        background: var(--bg-soft);
      }
      .integration-icon {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        background: var(--bg-soft);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-2);
        transition: background 0.2s ease;
      }
      .integration-card:hover .integration-icon {
        background: rgba(11, 107, 83, 0.1);
      }
      [data-theme="dark"] .integration-card:hover .integration-icon {
        background: rgba(187, 229, 91, 0.15);
      }
      [data-theme="dark"] .integration-name {
        color: var(--ink);
      }
      [data-theme="dark"] .integration-category {
        color: var(--muted);
      }
      [data-theme="dark"] .integrations-footer p {
        color: var(--muted);
      }
      [data-theme="dark"] .integrations-footer a {
        color: var(--pricing-accent);
      }
      .integration-icon svg {
        width: 24px;
        height: 24px;
        color: var(--muted);
        transition: color 0.2s ease;
      }
      .integration-card:hover .integration-icon svg {
        color: var(--pricing-accent);
      }
      .integration-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--ink);
        text-align: center;
        margin: 0;
      }
      .integration-category {
        font-size: 12px;
        color: var(--muted);
        margin-top: 4px;
      }
      .integrations-footer {
        text-align: center;
        max-width: 720px;
        margin: 0 auto;
      }
      .integrations-footer p {
        font-size: 14px;
        color: var(--muted);
        margin: var(--space-3) 0;
      }
      .integrations-footer a {
        color: var(--pricing-accent);
        font-weight: 500;
      }

      /* SCROLL REVEAL */
      .scroll-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .scroll-reveal.in-view {
        opacity: 1;
        transform: translateY(0);
      }

      /* RESPONSIVE */
      @media (max-width: 1200px) {
        .pricing-tiers {
          grid-template-columns: repeat(4, 280px);
          overflow-x: auto;
          padding-bottom: var(--space-2);
        }
      }
      @media (max-width: 768px) {
        :root {
          --navbar-height: 64px;
          --header-height: 64px;
        }
        .nav-links {
          display: none;
        }
        .menu-btn {
          display: block;
        }
        .pricing-tiers {
          grid-template-columns: repeat(4, 280px);
          overflow-x: auto;
          padding-bottom: var(--space-2);
        }
        .feature-table-wrapper {
          margin-left: calc(var(--space-4) * -1);
          margin-right: calc(var(--space-4) * -1);
        }
        .pricing-hero {
          padding-top: 32px;
          padding-bottom: 16px;
        }
        .optimization-loop {
          padding: var(--space-6) 0;
        }
        .integrations-section {
          padding: var(--space-6) 0;
        }
        .feature-table-section {
          padding: var(--space-6) 0;
        }
        .faq-section {
          padding: var(--space-6) 0;
        }
        .cta-section {
          padding: var(--space-6) 0;
          margin: var(--space-6) 0;
        }
      }
    </style>
  </head>
