              <div style="display: flex; flex-direction: column; gap: 6px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <span style="font-size: 12px; color: var(--muted);">Expected Uplift:</span>
                  <span id="roi-uplift" style="font-size: 14px; font-weight: 600; color: #16a34a;">+0%</span>
