    <!-- ROI Calculator Modal -->
    <div id="roi-calculator-modal" class="roi-modal" style="display: none;">
      <div class="roi-modal-backdrop" id="roi-modal-backdrop"></div>
      <div class="roi-modal-content">
        <div class="roi-modal-header">
          <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 6px;">
            <h2 style="font-size: 22px; font-weight: 600; margin: 0; line-height: 1.2;">Estimate Your Potential ROI</h2>
            <button id="roi-modal-close" class="roi-modal-close" aria-label="Close modal">×</button>
          </div>
          <p style="font-size: 14px; color: #6B7280; line-height: 1.5; margin: 0;">
            See how much extra revenue Grona's autonomous optimization could unlock for your website.
          </p>
        </div>
        
        <div class="roi-modal-body">
          <!-- Industry Selection -->
          <div class="roi-field" style="margin-bottom: 12px;">
            <label style="display: block; font-weight: 500; font-size: 14px; margin-bottom: 4px;">Industry</label>
            <p style="font-size: 12px; color: var(--muted); margin-bottom: 6px;">(Select the category that best matches your website)</p>
            <select id="roi-industry" style="width: 100%; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--line); background: var(--bg); font-size: 14px; height: 36px;">
              <option value="18">Ecommerce (Typical uplift: 18%)</option>
              <option value="22">SaaS (Typical uplift: 22%)</option>
